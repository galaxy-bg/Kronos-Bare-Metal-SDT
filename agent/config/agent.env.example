KDX_CONTROLLER_URL=http://192.168.88.240:8000
KDX_AGENT_INTERFACE=
KDX_HEARTBEAT_INTERVAL=60
KDX_DISCOVER_HPE_BMC=true
KDX_LINK_HPE_TOOLS=true
KDX_HPE_TOOL_LINK_DIR=/usr/local/bin
KDX_ENABLE_HPE_ACTIONS=true
KDX_ENABLE_RAID_ACTIONS=false

# Optional: enables boot-time iLO management IP discovery over local Redfish.
# Leave blank when credentials are unknown; UI actions can still provide them per task.
KDX_ILO_USERNAME=
KDX_ILO_PASSWORD=

# VM test fallback values. Real bare metal should read most of these from DMI.
KDX_SERIAL_NUMBER=CZJVMTEST001
KDX_VENDOR=HPE
KDX_MODEL=ProLiant DL380 Gen11
KDX_PRODUCT_NAME=P42124-B21
KDX_HOSTNAME=iLO-CZJVMTEST001

# BMC is usually unknown on first boot until management network config is set.
KDX_BMC_VENDOR=HPE
KDX_BMC_TYPE=iLO
KDX_BMC_IP=
